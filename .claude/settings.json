{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -File \".claude\\hooks\\zip-guard.ps1\"",
            "shell": "powershell",
            "statusMessage": "Checking for sensitive files in archive..."
          }
        ]
      }
    ]
  }
}
